<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/white">

    <!-- ORANGE TOP HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="#FF6900">

        <TextView
            android:id="@+id/drawerName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="User"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@android:color/white" />

        <TextView
            android:id="@+id/drawerEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="email"
            android:textSize="14sp"
            android:textColor="#D1D5DB"
            android:layout_marginTop="6dp" />
    </LinearLayout>

    <!-- COOKING SCORE CARD -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardCookingScore"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#F3F4F6"
        app:cardBackgroundColor="#FFF7ED">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Title + Trophy -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="COOKING SCORE"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:letterSpacing="0.12"
                    android:textColor="#FF6900" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@android:color/white">

                    <ImageView
                        android:id="@+id/ivTrophy"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="12dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_trophy" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Big score -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:baselineAligned="true">

                <TextView
                    android:id="@+id/tvCookedCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textStyle="bold"
                    android:textSize="42sp"
                    android:textColor="#111827" />

                <TextView
                    android:id="@+id/tvCookedLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="recipes"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="#9CA3AF" />
            </LinearLayout>

            <!-- Next level + x/y -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvNextLevel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Next: Beginner Chef"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="#374151" />

                <TextView
                    android:id="@+id/tvProgressText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0/5"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#9CA3AF" />
            </LinearLayout>

            <!-- Progress bar -->
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progressCooking"
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:layout_marginTop="10dp"
                android:max="100"
                android:progress="0"
                app:trackThickness="10dp"
                app:trackCornerRadius="12dp"
                app:trackColor="#FDEBD2"
                app:indicatorColor="#FF6900" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>